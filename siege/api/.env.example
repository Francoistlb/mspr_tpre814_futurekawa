# ============================================================
# FutureKawa — Backend Siège : variables d'environnement
# Copier ce fichier en .env et adapter les valeurs
# ============================================================

# Port d'écoute de l'API siège
PORT=8000

# URLs des APIs pays (docker-compose : noms de services)
# En développement local sans Docker : http://localhost:8001 etc.
BRESIL_API_URL=http://bresil-api:8000
EQUATEUR_API_URL=http://equateur-api:8000
COLOMBIE_API_URL=http://colombie-api:8000

# Timeout par requête vers une API pays (en secondes)
# Si dépassé, le pays est marqué "error" dans la réponse partielle
API_TIMEOUT_S=3
