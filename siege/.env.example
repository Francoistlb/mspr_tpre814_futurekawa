# ============================================================
# FutureKawa — Siege — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# En demo locale, les URLs pointent vers host.docker.internal
# ============================================================

# URLs des APIs pays (accessibles depuis le conteneur siege)
# En demo tout-en-un : utiliser les noms de service du compose racine
BRESIL_API_URL=http://host.docker.internal:8001
EQUATEUR_API_URL=http://host.docker.internal:8002
COLOMBIE_API_URL=http://host.docker.internal:8003

# Timeout par pays en secondes (evite de bloquer si un pays est down)
API_TIMEOUT_S=3

# Ports exposes
SIEGE_API_PORT=8000
FRONTEND_PORT=3000

# URL de l'API siege vue depuis le navigateur (pour le frontend)
VITE_SIEGE_API_URL=http://localhost:8000
