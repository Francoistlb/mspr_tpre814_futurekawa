# ============================================================
# FutureKawa — Equateur — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs sensibles
# Ne jamais committer le fichier .env
# ============================================================

# Base de donnees PostgreSQL
POSTGRES_DB=futurekawa_equateur
POSTGRES_USER=futurekawa
POSTGRES_PASSWORD=change_me_in_production

# Broker MQTT (port expose sur la machine hote)
MQTT_PORT=1884

# API REST (port expose sur la machine hote)
API_PORT=8002

# Identite pays
PAYS=equateur
PAYS_CODE=EQ

# Email — alertes
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
ALERT_EMAIL_RESPONSABLE=responsable.equateur@futurekawa.com
