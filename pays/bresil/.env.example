# ============================================================
# FutureKawa — Bresil — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs sensibles
# Ne jamais committer le fichier .env
# ============================================================

# Base de donnees PostgreSQL
POSTGRES_DB=futurekawa_bresil
POSTGRES_USER=futurekawa
POSTGRES_PASSWORD=change_me_in_production

# Broker MQTT (port expose sur la machine hote)
MQTT_PORT=1883

# API REST (port expose sur la machine hote)
API_PORT=8001

# Identite pays
PAYS=bresil
PAYS_CODE=BR

# Email — alertes (Mailhog en dev : SMTP_HOST=mailhog, SMTP_PORT=1025)
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
ALERT_EMAIL_RESPONSABLE=responsable.bresil@futurekawa.com
