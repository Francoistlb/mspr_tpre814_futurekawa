# ============================================================
# FutureKawa — Template de variables d'environnement
# Copier ce fichier en .env et adapter les valeurs
# ============================================================

# --- Email SMTP ----------------------------------------------
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=

# --- Alertes email par pays ----------------------------------
RESPONSABLE_EMAIL_BRESIL=responsable.bresil@futurekawa.com
RESPONSABLE_EMAIL_EQUATEUR=responsable.equateur@futurekawa.com
RESPONSABLE_EMAIL_COLOMBIE=responsable.colombie@futurekawa.com

# --- Siege API -----------------------------------------------
API_TIMEOUT_S=3
VITE_SIEGE_API_URL=http://localhost:8000

# --- Ports exposes -------------------------------------------
SIEGE_API_PORT=8000
FRONTEND_PORT=3000
